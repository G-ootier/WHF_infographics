<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>World Adherence Day 2026 – Survey Infographic</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --red:    #D42B2B;
    --cream:  #F2EBE0;
    --beige:  #EAE0D0;
    --white:  #FFFFFF;
    --dark:   #1C1C1C;
    --mid:    #5C5248;
    --rule:   #DDD4C4;
  }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--cream);
    color: var(--dark);
  }

  /* ─── PAGE WRAPPER ─── */
  .page {
    max-width: 860px;
    margin: 0 auto;
    background: var(--cream);
  }

  /* ─── HEADER ─── */
  .header {
    background: var(--white);
    padding: 48px 52px 40px;
    border-bottom: 3px solid var(--red);
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .header-logo {
    flex-shrink: 0;
  }
  .header-logo svg {
    width: 64px;
    height: 64px;
  }
  .header-text {}
  .header-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 8px;
  }
  .header-title {
    font-size: 26px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.2;
    color: var(--dark);
  }
  .header-title span { color: var(--red); }
  .header-sub {
    font-size: 12px;
    font-weight: 400;
    color: var(--mid);
    margin-top: 8px;
    font-style: italic;
  }

  /* ─── KEY MESSAGE BAND ─── */
  .key-message {
    background: var(--red);
    padding: 24px 52px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }
  .key-message-label {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .key-message-rule {
    width: 2px;
    background: rgba(255,255,255,0.3);
    align-self: stretch;
    flex-shrink: 0;
  }
  .key-message-text {
    font-size: 13.5px;
    color: white;
    line-height: 1.6;
    font-weight: 400;
  }
  .key-message-text strong { font-weight: 700; }

  /* ─── SECTION WRAPPER ─── */
  .section {
    padding: 44px 52px;
  }
  .section-white { background: var(--white); }
  .section-cream { background: var(--cream); }

  /* ─── SECTION HEADER ─── */
  .section-head {
    margin-bottom: 30px;
  }
  .section-number-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .section-num-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--red);
    flex-shrink: 0;
  }
  .section-num-text {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--red);
  }
  .section-title {
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    line-height: 1.2;
    color: var(--dark);
  }
  .section-title span { color: var(--red); }
  .section-subtitle {
    font-size: 12px;
    font-weight: 400;
    color: var(--mid);
    margin-top: 4px;
  }

  /* ─── ANCHOR STATS ─── */
  .stat-row {
    display: grid;
    gap: 14px;
    margin-bottom: 16px;
  }
  .cols-2 { grid-template-columns: 1fr 1fr; }
  .cols-3 { grid-template-columns: 1fr 1fr 1fr; }

  .stat-card {
    background: var(--white);
    border-radius: 4px;
    padding: 22px 20px;
    border-top: 3px solid var(--dark);
  }
  .stat-card.red-top { border-top-color: var(--red); }
  .stat-number {
    font-size: 40px;
    font-weight: 900;
    line-height: 1;
    color: var(--red);
    margin-bottom: 8px;
    letter-spacing: -1px;
  }
  .stat-label {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--dark);
    font-weight: 400;
  }
  .stat-label strong { font-weight: 700; }

  /* ─── CONSEQUENCE STRIP ─── */
  .consequence-strip {
    display: flex;
    background: var(--dark);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .consequence-item {
    flex: 1;
    padding: 14px 18px;
    border-right: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .consequence-item:last-child { border-right: none; }
  .con-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--red);
    flex-shrink: 0;
  }
  .con-text {
    font-size: 11.5px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    line-height: 1.3;
  }

  /* ─── REASONS ─── */
  .reasons-wrap {
    background: var(--white);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .reasons-head {
    padding: 10px 20px;
    background: var(--beige);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mid);
  }
  .reason-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--cream);
  }
  .reason-row:last-child { border-bottom: none; }
  .reason-rank {
    font-size: 11px;
    font-weight: 900;
    color: var(--red);
    width: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .reason-bar-wrap { flex: 1; }
  .reason-text {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 6px;
  }
  .reason-bar {
    height: 6px;
    background: var(--cream);
    border-radius: 3px;
    overflow: hidden;
  }
  .reason-fill {
    height: 100%;
    background: var(--red);
    border-radius: 3px;
  }
  .reason-pct {
    font-size: 20px;
    font-weight: 900;
    color: var(--red);
    min-width: 44px;
    text-align: right;
    letter-spacing: -0.5px;
  }

  /* ─── DEMO GRID ─── */
  .demo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 0;
  }
  .demo-card {
    background: var(--white);
    border-radius: 4px;
    padding: 22px 24px;
  }
  .demo-title {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 18px;
  }

  /* Pictograph rows */
  .picto-row {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 14px;
  }
  .picto-row:last-child { margin-bottom: 0; }
  .picto-figures {
    display: flex;
    gap: 3px;
    flex-shrink: 0;
  }
  .picto-figures svg { display: block; }
  .picto-info {
    flex: 1;
  }
  .picto-pct {
    font-size: 28px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -1px;
  }
  .picto-pct.red { color: var(--red); }
  .picto-pct.dark { color: var(--dark); }
  .picto-label {
    font-size: 11.5px;
    color: var(--dark);
    font-weight: 500;
    margin-top: 3px;
    line-height: 1.3;
  }
  .picto-sublabel {
    font-size: 10px;
    color: var(--mid);
    font-weight: 400;
    margin-top: 2px;
  }
  .picto-divider {
    height: 1px;
    background: var(--cream);
    margin: 14px 0;
  }

  /* Gender visual */
  .gender-visual {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 24px;
    margin-bottom: 20px;
    padding: 10px 0;
  }
  .gender-figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .gender-figure .g-pct {
    font-size: 26px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -1px;
  }
  .gender-figure .g-pct.red { color: var(--red); }
  .gender-figure .g-pct.muted { color: #B8AFA3; }
  .gender-figure .g-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--dark);
  }
  .gender-note {
    text-align: center;
    font-size: 10.5px;
    color: var(--mid);
    font-weight: 400;
    line-height: 1.4;
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid var(--cream);
  }
  .gender-note strong { font-weight: 700; color: var(--dark); }

  /* ─── SECTION DIVIDER ─── */
  .divider-band {
    padding: 14px 52px;
    background: var(--beige);
    text-align: center;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--mid);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .divider-band::before,
  .divider-band::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  /* ─── GAP CARDS ─── */
  .gap-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .gap-card {
    background: var(--cream);
    border-radius: 4px;
    padding: 22px 20px;
    border-left: 3px solid var(--red);
  }
  .gap-card-title {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--red);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .gap-stat-block {
    margin-bottom: 10px;
  }
  .gap-stat-block:last-child { margin-bottom: 0; }
  .gap-big-num {
    font-size: 28px;
    font-weight: 900;
    color: var(--dark);
    line-height: 1;
    letter-spacing: -0.5px;
  }
  .gap-desc {
    font-size: 11.5px;
    color: var(--dark);
    line-height: 1.45;
    margin-top: 3px;
    font-weight: 400;
  }
  .gap-desc strong { font-weight: 700; }
  .gap-rule {
    height: 1px;
    background: var(--rule);
    margin: 10px 0;
  }
  .gap-note {
    font-size: 11.5px;
    color: var(--mid);
    line-height: 1.45;
    font-weight: 400;
  }
  .gap-note strong { font-weight: 700; color: var(--dark); }

  /* ─── SOLUTION CARDS ─── */
  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .solution-card {
    background: var(--cream);
    border-radius: 4px;
    padding: 26px 22px;
    border-top: 3px solid var(--red);
    position: relative;
  }
  .solution-icon {
    margin-bottom: 14px;
  }
  .solution-icon svg {
    display: block;
  }
  .solution-pillar {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 4px;
  }
  .solution-title {
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--dark);
    margin-bottom: 14px;
    line-height: 1.25;
  }
  .solution-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .solution-list li {
    font-size: 12px;
    line-height: 1.45;
    color: var(--dark);
    padding-left: 14px;
    position: relative;
    font-weight: 400;
  }
  .solution-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--red);
  }

  /* ─── FOOTER ─── */
  .footer {
    background: var(--dark);
    padding: 20px 52px;
    text-align: center;
    font-size: 10.5px;
    color: rgba(255,255,255,0.4);
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  /* ─── STARBURST SVG ─── */
  /* used inline in header */
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header">
    <!-- WHF-style starburst logo -->
    <div class="header-logo">
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="32" cy="32" r="32" fill="#D42B2B"/>
        <!-- starburst spokes -->
        <g fill="white">
          <rect x="30.5" y="4" width="3" height="13" rx="1.5"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5"/>
          <rect x="4" y="30.5" width="13" height="3" rx="1.5"/>
          <rect x="47" y="30.5" width="13" height="3" rx="1.5"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(45 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(45 32 32)"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(90 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(90 32 32)"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(22.5 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(22.5 32 32)"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(67.5 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(67.5 32 32)"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(112.5 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(112.5 32 32)"/>
          <rect x="30.5" y="4" width="3" height="13" rx="1.5" transform="rotate(157.5 32 32)"/>
          <rect x="30.5" y="47" width="3" height="13" rx="1.5" transform="rotate(157.5 32 32)"/>
          <!-- play button in center -->
          <polygon points="28,25 28,39 41,32" fill="white"/>
        </g>
      </svg>
    </div>
    <div class="header-text">
      <div class="header-eyebrow">World Adherence Day 2026</div>
      <div class="header-title">Medication Adherence:<br><span>What Clinicians</span> Are Telling Us</div>
      <div class="header-sub">Data based primarily on developed countries</div>
    </div>
  </div>

  <!-- KEY MESSAGE -->
  <div class="key-message">
    <div class="key-message-label">Key<br>Message</div>
    <div class="key-message-rule"></div>
    <div class="key-message-text">
      Medication non-adherence is widely recognised as a <strong>major threat to patient outcomes.</strong> Yet healthcare professionals consistently lack the <strong>time, training, tools, and system support</strong> needed to address it effectively in routine care.
    </div>
  </div>

  <!-- ═══════════ SECTION 1 ═══════════ -->
  <div class="section section-white">

    <div class="section-head">
      <div class="section-number-tag">
        <div class="section-num-dot"></div>
        <div class="section-num-text">Section 01</div>
      </div>
      <div class="section-title">The <span>Scale</span> of the Problem</div>
      <div class="section-subtitle">How clinicians perceive non-adherence and why patients stop</div>
    </div>

    <div class="stat-row cols-2">
      <div class="stat-card red-top">
        <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:12px">
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" style="flex-shrink:0">
            <circle cx="22" cy="22" r="22" fill="#D42B2B" opacity="0.1"/>
            <path d="M22 10c-3 0-5.5 1-7.5 3s-3 4.5-3 7.5c0 6 10.5 14 10.5 14S32.5 26.5 32.5 20.5c0-3-1-5.5-3-7.5S25 10 22 10z" fill="#D42B2B" opacity="0.7"/>
            <path d="M19 21l2.5 2.5L26 18" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div class="stat-number" style="margin-bottom:0">9 in 10</div>
        </div>
        <div class="stat-label"><strong>Healthcare professionals</strong> say medication non-adherence is a <strong>moderate or major health problem</strong></div>
      </div>
      <div class="stat-card red-top">
        <div style="display:flex;gap:14px;align-items:flex-start;margin-bottom:12px">
          <svg width="44" height="44" viewBox="0 0 44 44" fill="none" style="flex-shrink:0">
            <circle cx="22" cy="22" r="22" fill="#D42B2B" opacity="0.1"/>
            <circle cx="16" cy="16" r="4" stroke="#D42B2B" stroke-width="1.8" fill="none"/>
            <path d="M10 30c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#D42B2B" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <circle cx="28" cy="16" r="4" stroke="#D42B2B" stroke-width="1.8" fill="none"/>
            <path d="M22 30c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#D42B2B" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M19 26h6" stroke="#D42B2B" stroke-width="1.8" stroke-linecap="round" stroke-dasharray="2 2"/>
          </svg>
          <div class="stat-number" style="margin-bottom:0">65%</div>
        </div>
        <div class="stat-label">of clinicians see adherence as a <strong>shared responsibility</strong> between patient and clinician, not simply a matter of taking medication as prescribed</div>
      </div>
    </div>

    <div class="consequence-strip">
      <div class="consequence-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z" stroke="#D42B2B" stroke-width="1.8"/><path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="#D42B2B" stroke-width="1.8" stroke-linecap="round" transform="rotate(180 12 14)"/><circle cx="9" cy="10" r="1" fill="#D42B2B"/><circle cx="15" cy="10" r="1" fill="#D42B2B"/></svg>
        <div class="con-text">Poorer patient outcomes</div>
      </div>
      <div class="consequence-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 21h18M5 21V7l7-4 7 4v14" stroke="#D42B2B" stroke-width="1.8" stroke-linejoin="round"/><path d="M10 21v-5h4v5" stroke="#D42B2B" stroke-width="1.8"/><rect x="9" y="9" width="2" height="2" fill="#D42B2B"/><rect x="13" y="9" width="2" height="2" fill="#D42B2B"/></svg>
        <div class="con-text">Increased hospitalisations</div>
      </div>
      <div class="consequence-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="#D42B2B" stroke-width="1.8" fill="none"/><path d="M7 12l3 3 7-7" stroke="#D42B2B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" opacity="0"/><line x1="8" y1="8" x2="16" y2="16" stroke="#D42B2B" stroke-width="1.5" stroke-linecap="round"/><line x1="16" y1="8" x2="8" y2="16" stroke="#D42B2B" stroke-width="1.5" stroke-linecap="round"/></svg>
        <div class="con-text">Premature mortality</div>
      </div>
    </div>

    <div class="reasons-wrap">
      <div class="reasons-head">Top reasons patients stop taking medication</div>
      <div class="reason-row">
        <div class="reason-rank">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="13" fill="#D42B2B" opacity="0.08"/><path d="M9 15s2 3 5 3 5-3 5-3" stroke="#D42B2B" stroke-width="1.6" stroke-linecap="round"/><circle cx="10.5" cy="11" r="1" fill="#D42B2B"/><circle cx="17.5" cy="11" r="1" fill="#D42B2B"/></svg>
        </div>
        <div class="reason-bar-wrap">
          <div class="reason-text">Patients stop when they feel better</div>
          <div class="reason-bar"><div class="reason-fill" style="width:64%"></div></div>
        </div>
        <div class="reason-pct">64%</div>
      </div>
